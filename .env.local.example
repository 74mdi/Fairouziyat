# Fairouziyat — required environment variables for Vercel
FAIROUZIYAT_DATABASE_URL=postgresql://user:pass@host/dbname?sslmode=require

# Optional: local filesystem paths (only for self-hosted / local dev)
# Leave empty on Vercel — audio and covers will gracefully return 503
# AUDIO_DIR=/path/to/audio/files
# COVERS_DIR=/path/to/cover/images
