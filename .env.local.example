# Fairouziyat — required environment variables for Vercel
FAIROUZIYAT_DATABASE_URL=postgresql://user:pass@host/dbname?sslmode=require

# Canonical site URL — used for SEO metadata, OG image URLs, and sitemap
NEXT_PUBLIC_SITE_URL=https://fairouziyat.vercel.app

# Optional: local filesystem paths (only for self-hosted / local dev)
# On Vercel: covers are served as static files from public/covers/ — COVERS_DIR is not needed
# AUDIO_DIR=/path/to/audio/files
# COVERS_DIR=/path/to/cover/images (local dev only)
